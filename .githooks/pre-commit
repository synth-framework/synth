#!/bin/sh
# ============================================================
# Synth Pre-Commit Hook
# ============================================================
# Runs the canonical governance pipeline before allowing a commit.
# This is the local enforcement of docs/governance.md.
#
# To install:
#   git config core.hooksPath .githooks
# ============================================================

echo ""
echo "═══════════════════════════════════════════════════"
echo "  SYNTH: Pre-Commit Governance Gate"
echo "═══════════════════════════════════════════════════"
echo ""

npm run govern
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Governance gate failed. Commit blocked."
  echo ""
  exit 1
fi

echo ""
echo "✅ Governance gate passed. Commit allowed."
echo ""
exit 0
